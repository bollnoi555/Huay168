TELEGRAM_BOT_TOKEN=put_your_bot_token_here

# Optional: comma-separated Telegram chat IDs to notify on startup.
TELEGRAM_DEFAULT_CHAT_IDS=

# Optional Lao API. If empty or unavailable, the bot uses the public fallback page.
LAO_API_KEY=
LAO_HISTORY_URL=https://api.apilotto.com/api/v1/laolottohistory
LAO_FALLBACK_URL=https://www.raakaadee.com/ตรวจหวย-หุ้น/หวยลาวพัฒนา/

# Thai lottery sources. The bot falls back to GitHub archive if the API is unavailable.
THAI_API_BASE=https://lotto.api.rayriffy.com
THAI_HISTORY_PAGES=3
THAI_ARCHIVE_RAW_BASE=https://raw.githubusercontent.com/vicha-w/thai-lotto-archive/master/lottonumbers

# Optional manual fallback data file.
MANUAL_RESULTS_FILE=data/manual_results.json

# Check interval for new-result notifications.
CHECK_INTERVAL_MINUTES=15
